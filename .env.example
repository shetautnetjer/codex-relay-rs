# Telegram transport configuration
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_BASE=https://api.telegram.org
TELEGRAM_POLL_TIMEOUT_SECS=30

# Relay defaults
RELAY_DEFAULT_AGENT=codex-default
RELAY_ARTIFACT_ROOT=./data/artifacts

# Chat allowlist (comma-separated Telegram chat IDs)
RELAY_ALLOWED_CHAT_IDS=

# Agent-to-channel binding (JSON map string)
# Format:
# {"agent_id":"telegram_chat_id","agent_reviewer":"-1001234567890"}
AGENT_CHANNEL_BINDINGS_JSON={}

# Optional explicit per-agent channel env vars (fallback style)
# AGENT_CHANNEL__<AGENT_ID>=<TELEGRAM_CHAT_ID>
# Example:
# AGENT_CHANNEL__CODEX_DEFAULT=-1001234567890
